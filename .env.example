# ─── Database (optional — only if using Docker) ─────────────
DATABASE_URL="postgresql://hostnet:hostnet_dev_password@localhost:5433/hostnet_panel"

# ─── API (hmail-api) ────────────────────────────────────────
API_PORT=4000
# Public URL for open/link tracking redirects (required in production behind a reverse proxy)
# PUBLIC_API_URL=https://api.yourdomain.com
# File vault storage (defaults to apps/hmail-api/uploads/vault/{tenantId}/)
# FILE_VAULT_UPLOAD_ROOT=
# FILE_VAULT_MAX_BYTES=104857600
# FILE_VAULT_LINK_TTL_DAYS=30
# MULTI_INBOX_MAX_ACCOUNTS=5
# INBOX_CLEANUP_MAX_SCAN=500
# INBOX_CLEANUP_SENDERS_LIMIT=25
# ATTACHMENT_CATEGORIZE_MAX_SCAN=200
# Dropbox Sign (HelloSign API v3) — Phase 1.6 e-sign from email
# DROPBOX_SIGN_API_KEY=
# DROPBOX_SIGN_TEST_MODE=true
# ESIGN_MAX_BYTES=26214400
# ESIGN_LINK_TTL_DAYS=30
# EMAIL_SLA_DEFAULT_HOURS=24
# EMAIL_SLA_MAX_SCAN=200
# EMAIL_SLA_AT_RISK_RATIO=0.8
# EMAIL_SLA_REPORT_LINK_TTL_DAYS=7
NODE_ENV=development
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
CREDENTIAL_ENCRYPTION_KEY="change-me-32-byte-hex-or-passphrase-derived"
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"
COOKIE_SECURE=false
ADMIN_DEFAULT_EMAIL=admin@hostnet.local
ADMIN_DEFAULT_PASSWORD=changeme123

# ─── Default Hostinger IMAP/SMTP (tenant overrides in DB) ───
DEFAULT_IMAP_HOST=imap.hostinger.com
DEFAULT_IMAP_PORT=993
DEFAULT_IMAP_SECURE=true
DEFAULT_SMTP_HOST=smtp.hostinger.com
DEFAULT_SMTP_PORT=465
DEFAULT_SMTP_SECURE=true

# ─── Web (hmail-web) ────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:4000

# ─── Web (hostnet-web landing) ────────────────────────────────
# Leave empty in dev so Vite proxy on :5174 keeps panel cookies on the same origin.
# VITE_API_BASE_URL=
VITE_HOSTNET_WEB_URL=http://localhost:5174
VITE_HMAIL_URL=http://localhost:5173/login
VITE_RECAPTCHA_SITE_KEY=
# PMail+ mobile install gate (production default: require PWA on viewports <=767px)
# VITE_PWA_INSTALL_GATE=false

# ─── PMail+ PWA push & calendar sync (hmail-api) ─────────────
# Required for mail push. Generate: cd apps/hmail-api && npx web-push generate-vapid-keys
# Restart hmail-api after setting. Super admin → System status shows VAPID status.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Optional server-side calendar tokens (or pass accessToken on connect API)
GOOGLE_CALENDAR_ACCESS_TOKEN=
MICROSOFT_GRAPH_ACCESS_TOKEN=

# ─── Sales pipeline & platform email (hmail-api) ───────────────
RECAPTCHA_SECRET_KEY=
MEMBERSHIP_NOTIFY_EMAIL=newclient@prohost.cloud
INQUIRY_NOTIFY_EMAIL=help@prohost.cloud
INQUIRY_REPLY_EMAIL=help@prohost.cloud
PLATFORM_EMAIL_FROM=noreply@prohost.cloud
PLATFORM_SMTP_HOST=
PLATFORM_SMTP_PORT=587
PLATFORM_SMTP_SECURE=false
PLATFORM_SMTP_USER=
PLATFORM_SMTP_PASS=

# ─── Marketing AI (optional — configure provider in admin UI) ─
MARKETING_AI_API_KEY=
OPENAI_API_KEY=
# Set to false to force template-based Growth agent outputs (default: auto when API key present)
GROWTH_USE_LLM=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
# Job Hunter CV scanner — max upload size in bytes (default 5MB)
JOB_HUNTER_CV_MAX_BYTES=5242880
# Max messages scanned per folder during Job Hunter mail sync (default 200)
JOB_HUNTER_MAX_SCAN=200
# QA: shorten Job Hunter career trial in minutes (omit in production — defaults to 30 days)
# JOB_HUNTER_TRIAL_MINUTES=1
# Set to false to disable Job Hunter LLM (scanner returns 503)
JOB_HUNTER_USE_LLM=

# ─── Payments (Stripe + Paystack) ─────────────────────────────
# Leave keys empty in dev to use demo/mock checkout automatically.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYMENT_DEFAULT_CURRENCY=usd
PAYMENT_MOCK_MODE=true
PAYMENT_SUCCESS_URL=http://localhost:5174/checkout/success
PAYMENT_CANCEL_URL=http://localhost:5174/checkout/cancel
HOSTNET_WEB_URL=http://localhost:5174

# ─── WhatsApp (platform add-on) ───────────────────────────────
# Provider: twilio | meta
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=

# ─── PMail+ tester account (local dev) ───────────────────────
# Set PMAIL_TESTER_BYPASS_AUTH=true to log in without IMAP credentials.
PMAIL_TESTER_BYPASS_AUTH=true
PMAIL_TESTER_EMAIL=pmailtester@gmail.com
PMAIL_TESTER_PASSWORD=mailtester1234
PMAIL_TESTER_TENANT_SLUG=pmail-tester
# Set true to unlock all add-ons for the tester account (dev convenience).
PMAIL_TESTER_UNLOCK_ALL_ADDONS=false
