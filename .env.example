# ─── Database (optional — only if using Docker) ─────────────
DATABASE_URL="postgresql://hostnet:hostnet_dev_password@localhost:5433/hostnet_panel"

# ─── API (hmail-api) ────────────────────────────────────────
API_PORT=4000
NODE_ENV=development
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
CREDENTIAL_ENCRYPTION_KEY="change-me-32-byte-hex-or-passphrase-derived"
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"
COOKIE_SECURE=false
ADMIN_DEFAULT_EMAIL=admin@hostnet.local
ADMIN_DEFAULT_PASSWORD=changeme123

# ─── Default Hostinger IMAP/SMTP (tenant overrides in DB) ───
DEFAULT_IMAP_HOST=imap.hostinger.com
DEFAULT_IMAP_PORT=993
DEFAULT_IMAP_SECURE=true
DEFAULT_SMTP_HOST=smtp.hostinger.com
DEFAULT_SMTP_PORT=465
DEFAULT_SMTP_SECURE=true

# ─── Web (hmail-web) ────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:4000

# ─── Web (hostnet-web landing) ────────────────────────────────
# Leave empty in dev so Vite proxy on :5174 keeps panel cookies on the same origin.
# VITE_API_BASE_URL=
VITE_HOSTNET_WEB_URL=http://localhost:5174
VITE_HMAIL_URL=http://localhost:5173/login
VITE_RECAPTCHA_SITE_KEY=

# ─── Sales pipeline & platform email (hmail-api) ───────────────
RECAPTCHA_SECRET_KEY=
MEMBERSHIP_NOTIFY_EMAIL=newclient@prohost.cloud
INQUIRY_NOTIFY_EMAIL=help@prohost.cloud
INQUIRY_REPLY_EMAIL=help@prohost.cloud
PLATFORM_EMAIL_FROM=noreply@prohost.cloud
PLATFORM_SMTP_HOST=
PLATFORM_SMTP_PORT=587
PLATFORM_SMTP_SECURE=false
PLATFORM_SMTP_USER=
PLATFORM_SMTP_PASS=

# ─── Marketing AI (optional — configure provider in admin UI) ─
MARKETING_AI_API_KEY=
OPENAI_API_KEY=
# Set to false to force template-based Growth agent outputs (default: auto when API key present)
GROWTH_USE_LLM=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# ─── Payments (Stripe + Paystack) ─────────────────────────────
# Leave keys empty in dev to use demo/mock checkout automatically.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYMENT_DEFAULT_CURRENCY=usd
PAYMENT_MOCK_MODE=true
PAYMENT_SUCCESS_URL=http://localhost:5174/checkout/success
PAYMENT_CANCEL_URL=http://localhost:5174/checkout/cancel
HOSTNET_WEB_URL=http://localhost:5174

# ─── WhatsApp (platform add-on) ───────────────────────────────
# Provider: twilio | meta
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=

# ─── PMail+ tester account (local dev) ───────────────────────
# Set PMAIL_TESTER_BYPASS_AUTH=true to log in without IMAP credentials.
PMAIL_TESTER_BYPASS_AUTH=true
PMAIL_TESTER_EMAIL=pmailtester@gmail.com
PMAIL_TESTER_PASSWORD=mailtester1234
PMAIL_TESTER_TENANT_SLUG=pmail-tester
