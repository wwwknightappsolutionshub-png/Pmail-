# ─── Free cloud PostgreSQL (Neon, Supabase, etc.) — no local DB install ───
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

API_PORT=4000
NODE_ENV=development
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
CREDENTIAL_ENCRYPTION_KEY="change-me-32-byte-hex-or-passphrase-derived"
CORS_ORIGIN="http://localhost:5173"
COOKIE_SECURE=false

DEFAULT_IMAP_HOST=imap.hostinger.com
DEFAULT_IMAP_PORT=993
DEFAULT_IMAP_SECURE=true
DEFAULT_SMTP_HOST=smtp.hostinger.com
DEFAULT_SMTP_PORT=465
DEFAULT_SMTP_SECURE=true

VITE_API_BASE_URL=http://localhost:4000
