  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace GrowthWorkspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  runs      GrowthAutomationRun[]

  @@index([workspaceId, triggerType, isActive])
  @@index([tenantId])
}

model GrowthAutomationRun {
  id           String   @id @default(uuid())
  tenantId     String
  workspaceId  String
  automationId String
  leadId       String?
  status       String
  triggerEvent String
  resultJson   String   @default("{}")
  errorMessage String?
  createdAt    DateTime @default(now())

  automation GrowthAutomation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([automationId, createdAt])
  @@index([leadId])
}

// ── Prohost Growth — Phase F SaaS packaging ──────────────────────────────────

model GrowthWorkspaceSettings {
  id           String   @id @default(uuid())
  tenantId     String
  workspaceId  String   @unique
  planSlug     String   @default("starter")
  planTierOverride Boolean @default(false)
  notifyEmail  String?
  settingsJson String   @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace GrowthWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model GrowthTeamMember {
  id               String   @id @default(uuid())
  tenantId         String
  workspaceId      String
  email            String
  role             String   @default("marketer")
  hostingAccountId String?
  invitedAt        DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace GrowthWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
  @@index([tenantId])
  @@index([workspaceId, role])
}

// ── Prohost Growth — Phase H optimization loop ───────────────────────────────

model GrowthOptimizationInsight {
  id           String   @id @default(uuid())
  tenantId     String
  workspaceId  String
  category     String
  priority     String   @default("medium")
  title        String
  summary      String
  actionLabel  String?
  actionTarget String?
  metricsJson  String   @default("{}")
  status       String   @default("open")
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace GrowthWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status, sortOrder])
  @@index([tenantId])
}

model GrowthChannelDelivery {
  id             String    @id @default(uuid())
  tenantId       String
  workspaceId    String
  channelType    String
  assetId        String?
  status         String    @default("scheduled")
  platform       String?
  scheduledAt    DateTime?
  sentAt         DateTime?
  recipientEmail String?
  payloadJson    String    @default("{}")
  resultJson     String    @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  workspace GrowthWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status, scheduledAt])
  @@index([tenantId])
}

model GrowthWeeklyBrief {
  id            String    @id @default(uuid())
  tenantId      String
  workspaceId   String
  weekStart     DateTime
  briefMarkdown String
  insightCount  Int       @default(0)
  emailedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  workspace GrowthWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, weekStart])
  @@index([tenantId])
}

model GrowthChannelIntegration {
  id              String   @id @default(uuid())
  tenantId        String
  workspaceId     String
  provider        String
  status          String   @default("connected")
  credentialsEnc  String?
  metadataJson    String   @default("{}")
  lastSyncAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace GrowthWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, provider])
  @@index([tenantId])
}

model GrowthAdCampaign {
  id               String   @id @default(uuid())
  tenantId         String
  workspaceId      String
  platform         String
  name             String
  status           String   @default("draft")
  dailyBudgetCents Int      @default(0)
  spentCents       Int      @default(0)
  externalId       String?
  adCopyAssetId    String?
  pacingJson       String   @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace GrowthWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, platform])
  @@index([tenantId])
}

model GrowthSeoKeyword {
  id            String    @id @default(uuid())
  tenantId      String
  workspaceId   String
  keyword       String
  targetUrl     String?
  currentRank   Int?
  previousRank  Int?
  searchVolume  Int?
  lastCheckedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  workspace GrowthWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, keyword])
  @@index([tenantId])
