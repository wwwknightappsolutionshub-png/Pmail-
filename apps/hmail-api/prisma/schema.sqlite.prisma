generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Multi-tenant organization (church, business, reseller client)
model Tenant {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branding TenantBranding?
  mail     TenantMailConfig?
  users    User[]
  addonTrials TenantAddonTrial[]
  addonSubscriptions TenantAddonSubscription[]
  userAddonSubscriptions UserAddonSubscription[]
  addonEmailLogs AddonEmailLog[]
  clients Client[]
  matters Matter[]
  immigrationTemplates ImmigrationTemplate[]
  scheduledMessages ScheduledMessage[]
  complianceLogs ComplianceAuditLog[]
  irccClassifications IrccMailClassification[]
  mailMatterLinks MailMatterLink[]
  matterDeadlines MatterDeadline[]
  portalAccesses PortalAccess[]
  portalDocumentRequests PortalDocumentRequest[]
  hostingAccounts HostingAccount[]
  vpsInstances VpsInstance[]
  paymentCheckouts PaymentCheckout[]
  hostingPlanSubscriptions HostingPlanSubscription[]
  crmPipelineStages CrmPipelineStage[]
  marketingLeads MarketingLead[]
  pmailReferralLeads PmailReferralLead[]
  membershipApplications MembershipApplication[]
  growthWorkspace GrowthWorkspace?
  reContacts ReContact[]
  reListings ReListing[]
  reShowings ReShowing[]
  reQuickReplyTemplates ReQuickReplyTemplate[]
  reDeals ReDeal[]
  acContacts AcContact[]
  acDocumentRequests AcDocumentRequest[]
  acFilingDeadlines AcFilingDeadline[]
  acSecureTemplates AcSecureTemplate[]
  acClientEntities AcClientEntity[]
  acDocumentExchangeRecords AcDocumentExchangeRecord[]
  rcContacts RcContact[]
  rcRoles RcRole[]
  rcInterviews RcInterview[]
  rcOutreachTemplates RcOutreachTemplate[]
  rcCandidateSubmissions RcCandidateSubmission[]
  rcOutreachCampaigns RcOutreachCampaign[]
  rcPlacements RcPlacement[]
  rcReferenceChecks RcReferenceCheck[]
  b2bContacts B2bContact[]
  b2bWorkspaces B2bWorkspace[]
  b2bMilestones B2bMilestone[]
  b2bProposalTemplates B2bProposalTemplate[]
  b2bDeliverables B2bDeliverable[]
  b2bProposals B2bProposal[]
  b2bSlaCases B2bSlaCase[]
  b2bSlaEvents B2bSlaEvent[]
  hcContacts HcContact[]
  hcPatientCharts HcPatientChart[]
  hcAppointments HcAppointment[]
  hcReferralTemplates HcReferralTemplate[]
  hcReferrals HcReferral[]
  hcAuditCases HcAuditCase[]
  hcAccessLogs HcAccessLog[]
}

model TenantBranding {
  id              String  @id @default(uuid())
  tenantId        String  @unique
  productName     String  @default("PMail+")
  logoUrl         String?
  primaryColor    String  @default("#0d9488")
  accentColor     String  @default("#14b8a6")
  backgroundColor String  @default("#0f172a")
  loginTagline    String  @default("Mail built for Canadian immigration professionals")
  industryProfile String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantMailConfig {
  id         String  @id @default(uuid())
  tenantId   String  @unique
  imapHost   String  @default("imap.hostinger.com")
  imapPort   Int     @default(993)
  imapSecure Boolean @default(true)
  smtpHost   String  @default("smtp.hostinger.com")
  smtpPort   Int     @default(465)
  smtpSecure Boolean @default(true)
  mailOnboardingComplete Boolean @default(false)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model User {
  id          String    @id @default(uuid())
  tenantId    String
  email       String
  displayName String?
  businessVertical String?
  uiThemeVersion String @default("dark")
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions       Session[]
  mailContacts   MailContact[]
  contactLists   MailContactList[]
  contactGroups  MailContactGroup[]
  composeSettings UserComposeSettings?
  signatures     UserSignature[]
  autoReplies    UserAutoReply[]
  sentTracking   SentMessageTracking[]
  crmRecords     CrmRecord[]
  workspaceReminders WorkspaceReminder[]
  workspaceCalendarEvents WorkspaceCalendarEvent[]
  calendarSettings WorkspaceCalendarSettings?
  industryTools  IndustryToolState[]
  autoReplyLogs  AutoReplySentLog[]
  reListingsAssigned ReListing[] @relation("ReListingAssignedAgent")
  reDealNotes      ReDealNote[]
  acDocumentRequestsAssigned AcDocumentRequest[] @relation("AcDocumentRequestAssignedUser")
  acEntityNotes              AcEntityNote[]
  acDocumentExchangeRecords  AcDocumentExchangeRecord[]
  rcRolesAssigned            RcRole[]            @relation("RcRoleAssignedUser")
  rcOutreachCampaigns        RcOutreachCampaign[]
  rcPlacementNotes           RcPlacementNote[]
  rcReferenceChecks          RcReferenceCheck[]
  b2bWorkspacesAssigned      B2bWorkspace[]      @relation("B2bWorkspaceAssignedUser")
  b2bSlaNotes                B2bSlaNote[]
  b2bProposalsAuthored       B2bProposal[]       @relation("B2bProposalAuthor")
  b2bSlaEvents               B2bSlaEvent[]
  hcPatientChartsAssigned    HcPatientChart[]    @relation("HcPatientChartAssignedUser")
  hcAuditNotes               HcAuditNote[]
  hcAccessLogs               HcAccessLog[]
  mailConfig                 UserMailConfig?
  addonSubscriptions         UserAddonSubscription[]
  pmailReferralsSent         PmailReferralLead[] @relation("PmailReferralSender")
  pmailReferralsConverted    PmailReferralLead[] @relation("PmailReferralConverted")

  @@unique([tenantId, email])
  @@index([businessVertical])
  @@index([email])
}

model UserMailConfig {
  id             String   @id @default(uuid())
  userId         String   @unique
  providerPreset String
  imapHost       String
  imapPort       Int      @default(993)
  imapSecure     Boolean  @default(true)
  smtpHost       String
  smtpPort       Int      @default(465)
  smtpSecure     Boolean  @default(true)
  configuredAt   DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MailContact {
  id        String   @id @default(uuid())
  userId    String
  email     String
  firstName String?
  lastName  String?
  phone     String?
  company   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listMembers  MailContactListMember[]
  groupMembers MailContactGroupMember[]

  @@unique([userId, email])
  @@index([userId])
}

model MailContactList {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  members MailContactListMember[]

  @@unique([userId, name])
  @@index([userId])
}

model MailContactListMember {
  id        String   @id @default(uuid())
  listId    String
  contactId String
  createdAt DateTime @default(now())

  list    MailContactList @relation(fields: [listId], references: [id], onDelete: Cascade)
  contact MailContact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([listId, contactId])
}

model MailContactGroup {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  members MailContactGroupMember[]

  @@unique([userId, name])
  @@index([userId])
}

model MailContactGroupMember {
  id        String   @id @default(uuid())
  groupId   String
  contactId String
  createdAt DateTime @default(now())

  group   MailContactGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  contact MailContact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([groupId, contactId])
}

model Session {
  id                    String   @id @default(uuid())
  userId                String
  tokenHash             String   @unique
  encryptedMailPassword String
  expiresAt             DateTime
  createdAt             DateTime @default(now())
  ipAddress             String?
  userAgent             String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model HostingAccount {
  id           String   @id @default(uuid())
  tenantId     String
  planId       String?
  username     String
  domain       String
  homePath     String
  diskQuotaMb  Int      @default(1024)
  diskUsedMb   Int      @default(0)
  bandwidthMb  Int      @default(10240)
  bandwidthUsedMb Int   @default(0)
  emailAccounts Int     @default(5)
  databases    Int      @default(1)
  passwordHash String
  isSuspended  Boolean  @default(false)
  isSampleDemo Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan     HostingPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  sessions PanelSession[]
  panelFiles PanelFileEntry[]
  panelDatabases PanelDatabase[]
  panelDomains PanelAddonDomain[]
  panelMailboxes PanelMailbox[]

  @@unique([tenantId, username])
  @@unique([username, domain])
  @@index([domain])
}

model PanelSession {
  id               String   @id @default(uuid())
  hostingAccountId String
  tokenHash        String   @unique
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  ipAddress        String?
  userAgent        String?

  hostingAccount HostingAccount @relation(fields: [hostingAccountId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model Addon {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  group       String
  vertical    String   @default("platform")
  addonKind   String   @default("vertical")
  description String
  features    String
  priceCents  Int      @default(1000)
  tenantPriceCents Int  @default(1000)
  minTenantSeats Int    @default(1)
  isPaid      Boolean  @default(true)
  releasePhase Int     @default(1)
  comingSoon  Boolean  @default(false)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trials        TenantAddonTrial[]
  subscriptions TenantAddonSubscription[]
  userSubscriptions UserAddonSubscription[]
  marketing     AddonMarketing?

  @@index([vertical, addonKind])
  @@index([isActive, deletedAt])
}

model TenantAddonTrial {
  id                String   @id @default(uuid())
  tenantId          String
  addonId           String
  startedAt         DateTime @default(now())
  endsAt            DateTime
  status            String   @default("active")
  welcomeEmailSent  Boolean  @default(false)
  day3EmailSent     Boolean  @default(false)
  discountEmailSent Boolean  @default(false)
  expiredEmailSent  Boolean  @default(false)
  trialSource       String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  addon  Addon  @relation(fields: [addonId], references: [id], onDelete: Cascade)

  @@unique([tenantId, addonId])
  @@index([status, endsAt])
}

model TenantAddonSubscription {
  id                     String    @id @default(uuid())
  tenantId               String
  addonId                String
  scope                  String    @default("tenant")
  seats                  Int       @default(5)
  priceCentsPerSeat      Int       @default(0)
  status                 String    @default("active")
  paymentProvider        String?
  stripeSubscriptionId   String?
  paystackSubscriptionCode String?
  paystackCustomerCode   String?
  currentPeriodEnd       DateTime?
  pastDueSince           DateTime?
  canceledAt             DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  addon  Addon  @relation(fields: [addonId], references: [id], onDelete: Cascade)

  @@unique([tenantId, addonId])
  @@index([status, currentPeriodEnd])
}

model UserAddonSubscription {
  id                 String    @id @default(uuid())
  tenantId           String
  userId             String
  addonId            String
  scope              String    @default("user")
  status             String    @default("active")
  priceCents         Int       @default(0)
  currentPeriodStart DateTime  @default(now())
  currentPeriodEnd   DateTime?
  canceledAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  addon  Addon  @relation(fields: [addonId], references: [id], onDelete: Cascade)

  @@unique([userId, addonId])
  @@index([tenantId, status])
  @@index([status, currentPeriodEnd])
}

model AddonEmailLog {
  id        String   @id @default(uuid())
  tenantId  String
  addonId   String?
  userEmail String
  emailType String
  sentAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, emailType])
}

model ImmigrationTemplate {
  id          String   @id @default(uuid())
  tenantId    String?
  slug        String
  name        String
  subject     String
  bodyHtml    String
  description String
  category    String   @default("general")
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([category])
}

model ScheduledMessage {
  id           String    @id @default(uuid())
  tenantId     String
  userId       String
  to           String
  cc           String?
  bcc          String?
  subject      String
  text         String?
  html         String?
  scheduledFor DateTime
  status       String    @default("pending")
  sentAt       DateTime?
  errorMessage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, scheduledFor])
}

model Client {
  id        String   @id @default(uuid())
  tenantId  String
  firstName String
  lastName  String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matters Matter[]

  @@index([tenantId, lastName])
}

model Matter {
  id        String   @id @default(uuid())
  tenantId  String
  clientId  String
  title     String
  uci       String?
  program   String   @default("express_entry")
  status    String   @default("intake")
  openedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client          Client                   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  checklistItems  MatterChecklistItem[]
  mailLinks       MailMatterLink[]
  deadlines       MatterDeadline[]
  portalAccesses  PortalAccess[]
  portalDocuments PortalDocumentRequest[]

  @@index([tenantId, uci])
  @@index([tenantId, status])
}

model MatterChecklistItem {
  id         String    @id @default(uuid())
  matterId   String
  label      String
  category   String    @default("document")
  isComplete Boolean   @default(false)
  dueDate    DateTime?
  sortOrder  Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  matter Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@index([matterId, sortOrder])
}

model ComplianceAuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String?
  userEmail  String?
  action     String
  entityType String?
  entityId   String?
  metadata   String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}

model IrccMailClassification {
  id             String   @id @default(uuid())
  tenantId       String
  folder         String
  messageUid     Int
  classification String
  priority       String   @default("normal")
  sender         String?
  subject        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, folder, messageUid])
  @@index([tenantId, priority])
}

model MailMatterLink {
  id         String   @id @default(uuid())
  tenantId   String
  matterId   String
  folder     String
  messageUid Int
  subject    String?
  linkedAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matter Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@unique([tenantId, folder, messageUid])
  @@index([matterId])
}

model MatterDeadline {
  id        String   @id @default(uuid())
  tenantId  String
  matterId  String
  title     String
  dueAt     DateTime
  status    String   @default("open")
  source    String   @default("manual")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matter Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@index([tenantId, dueAt])
  @@index([matterId])
}

// ── Real estate add-ons (Phase 1 parity with legal desk) ─────────────────────

model ReContact {
  id        String   @id @default(uuid())
  tenantId  String
  firstName String
  lastName  String
  email     String?
  phone     String?
  role      String   @default("buyer")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listingsSold  ReListing[] @relation("ReListingSeller")
  showings      ReShowing[]
  dealsAsBuyer  ReDeal[]    @relation("ReDealBuyer")

  @@index([tenantId, lastName])
}

model ReListing {
  id              String   @id @default(uuid())
  tenantId        String
  address         String
  city            String
  province        String?
  postalCode      String?
  mlsNumber       String?
  listPriceCents  Int?
  status          String   @default("active")
  assignedUserId  String?
  sellerContactId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant         Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedAgent  User?      @relation("ReListingAssignedAgent", fields: [assignedUserId], references: [id], onDelete: SetNull)
  sellerContact  ReContact? @relation("ReListingSeller", fields: [sellerContactId], references: [id], onDelete: SetNull)
  showings       ReShowing[]
  deals          ReDeal[]

  @@index([tenantId, status])
  @@index([tenantId, mlsNumber])
}

model ReShowing {
  id          String   @id @default(uuid())
  tenantId    String
  listingId   String
  contactId   String
  scheduledAt DateTime
  status      String   @default("scheduled")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant  Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listing ReListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  contact ReContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId, scheduledAt])
  @@index([listingId])
}

model ReQuickReplyTemplate {
  id          String   @id @default(uuid())
  tenantId    String?
  slug        String
  name        String
  subject     String
  bodyHtml    String
  description String
  category    String   @default("general")
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([category])
}

model ReDeal {
  id               String   @id @default(uuid())
  tenantId         String
  listingId        String
  title            String
  status           String   @default("offer")
  offerAmountCents Int?
  buyerContactId   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listing      ReListing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerContact ReContact?  @relation("ReDealBuyer", fields: [buyerContactId], references: [id], onDelete: SetNull)
  notes        ReDealNote[]

  @@index([tenantId, status])
  @@index([listingId])
}

model ReDealNote {
  id        String   @id @default(uuid())
  dealId    String
  userId    String
  body      String
  createdAt DateTime @default(now())

  deal ReDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([dealId, createdAt])
}

// ── Accounting add-ons ───────────────────────────────────────────────────────

model AcContact {
  id        String   @id @default(uuid())
  tenantId  String
  firstName String
  lastName  String
  email     String?
  phone     String?
  role      String   @default("client")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant               Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documentRequestsAsClient AcDocumentRequest[] @relation("AcDocumentRequestClient")
  filingDeadlines      AcFilingDeadline[]
  entitiesAsPrimary    AcClientEntity[]    @relation("AcClientEntityPrimaryContact")
  exchangeRecords      AcDocumentExchangeRecord[]

  @@index([tenantId, lastName])
}

model AcDocumentRequest {
  id               String   @id @default(uuid())
  tenantId         String
  title            String
  description      String?
  status           String   @default("open")
  referenceCode    String?
  category         String   @default("source_document")
  vaultStatus      String   @default("requested")
  fiscalYear       String?
  periodStart      DateTime?
  periodEnd        DateTime?
  dueAt            DateTime?
  reminderAt       DateTime?
  requestedAt      DateTime @default(now())
  receivedAt       DateTime?
  assignedUserId   String?
  clientContactId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant         Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedUser   User?      @relation("AcDocumentRequestAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  clientContact  AcContact? @relation("AcDocumentRequestClient", fields: [clientContactId], references: [id], onDelete: SetNull)
  exchangeRecords AcDocumentExchangeRecord[]

  @@index([tenantId, status])
  @@index([tenantId, category])
  @@index([tenantId, dueAt])
  @@index([tenantId, referenceCode])
}

model AcFilingDeadline {
  id             String   @id @default(uuid())
  tenantId       String
  clientEntityId String
  contactId      String
  dueAt          DateTime
  status         String   @default("open")
  filingType     String   @default("corporate_tax")
  taxPeriod      String
  periodStart    DateTime?
  periodEnd      DateTime?
  reminderAt     DateTime?
  filedAt        DateTime?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientEntity AcClientEntity @relation(fields: [clientEntityId], references: [id], onDelete: Cascade)
  contact      AcContact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId, dueAt])
  @@index([tenantId, filingType])
  @@index([tenantId, status])
  @@index([clientEntityId])
}

model AcSecureTemplate {
  id          String   @id @default(uuid())
  tenantId    String?
  slug        String
  name        String
  subject     String
  bodyHtml    String
  description String
  category    String   @default("general")
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([category])
}

model AcClientEntity {
  id                String   @id @default(uuid())
  tenantId          String
  name              String
  entityType        String
  taxId             String?
  taxIdentifierType String   @default("business_number")
